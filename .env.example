# ─── School-SIS Environment Variables ─────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to version control!

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://school_admin:CHANGE_ME@localhost:5432/school_sis

# ─── Authentication ───────────────────────────────────────
SESSION_SECRET=generate-a-32-char-random-string-here
ENCRYPTION_KEY=generate-a-32-char-hex-string-here

# ─── Application ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── File Storage ─────────────────────────────────────────
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
# For S3:
# STORAGE_PROVIDER=s3
# S3_BUCKET=school-sis-uploads
# S3_REGION=ap-south-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── Background Jobs ─────────────────────────────────────
JOB_QUEUE_MODE=database
JOB_DISPATCH_SECRET=generate-a-32-char-random-string-here

# ─── Performance / Scale ─────────────────────────────────
# Upstash is preferred for production auth throttling; Postgres fallback is automatic.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_BACKEND=postgres
BUNDLE_MAX_TOTAL_KB=10000
BUNDLE_MAX_ROUTE_KB=2500
LOAD_TEST_BASE_URL=http://localhost:3000
LOAD_TEST_DURATION_SECONDS=15
LOAD_TEST_CONCURRENCY=5
LOAD_TEST_PATHS=/api/health,/login

# ─── Observability / SRE ─────────────────────────────────
METRICS_TOKEN=generate-a-32-char-random-string-here
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Razorpay (Payment Gateway) ──────────────────────────
# RAZORPAY_KEY_ID=rzp_live_xxxxx
# RAZORPAY_SECRET=xxxxx

# ─── Communication (SMS/WhatsApp) ─────────────────────────
EMAIL_PROVIDER=mock
SMS_PROVIDER=mock
WHATSAPP_PROVIDER=mock
PUSH_PROVIDER=mock
# GUPSHUP_API_KEY=
# GUPSHUP_APP_NAME=
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
# RESEND_API_KEY=

# ─── Docker Compose ──────────────────────────────────────
# DB_PASSWORD=school_sis_dev_2026
