{
  "name": "school-sis",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "pnpm --filter @school-sis/web run test:unit",
    "test:unit:coverage": "pnpm --filter @school-sis/web run test:unit:coverage",
    "test:architecture": "pnpm --filter @school-sis/web run test:architecture",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:smoke": "pnpm --filter @school-sis/web run test:e2e:smoke",
    "db:generate": "pnpm --filter @school-sis/web run db:generate",
    "db:migrate": "pnpm --filter @school-sis/web run db:migrate",
    "db:migrate:prod": "pnpm --filter @school-sis/web run db:migrate:prod",
    "db:push": "pnpm --filter @school-sis/web run db:push",
    "db:seed": "pnpm --filter @school-sis/web run db:seed",
    "db:studio": "pnpm --filter @school-sis/web run db:studio",
    "infra:check": "pnpm --filter @school-sis/web run infra:check",
    "backup:create": "pnpm --filter @school-sis/web run backup:create",
    "backup:restore": "pnpm --filter @school-sis/web run backup:restore",
    "perf:bundle": "pnpm --filter @school-sis/web run perf:bundle",
    "perf:load": "pnpm --filter @school-sis/web run perf:load",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "audit:security": "pnpm audit --audit-level=high",
    "audit:secrets": "node scripts/check-secret-patterns.mjs",
    "audit:ci": "pnpm audit:security && pnpm audit:secrets",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "next": "^16.2.5",
    "prettier": "^3.2.0",
    "ts-jest": "^29.4.9",
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=9.0.7",
      "flatted": ">=3.4.2",
      "dompurify": ">=3.3.2",
      "lodash": ">=4.17.23",
      "jspdf": ">=4.2.1",
      "jsonwebtoken": ">=9.0.2",
      "picomatch": ">=4.0.4",
      "next": ">=16.2.5"
    }
  }
}
