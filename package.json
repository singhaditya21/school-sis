{
  "name": "school-sis",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "pnpm --filter @school-sis/web run test:unit",
    "test:unit:coverage": "pnpm --filter @school-sis/web run test:unit:coverage",
    "test:architecture": "pnpm --filter @school-sis/web run test:architecture",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:smoke": "pnpm --filter @school-sis/web run test:e2e:smoke",
    "local:setup": "bash scripts/local-setup.sh",
    "db:up": "bash scripts/local-db.sh up",
    "db:down": "bash scripts/local-db.sh down",
    "db:reset": "bash scripts/local-db.sh reset",
    "db:generate": "pnpm --filter @school-sis/web run db:generate",
    "db:migrate": "pnpm --filter @school-sis/web run db:migrate",
    "db:push": "pnpm --filter @school-sis/web run db:push",
    "db:seed": "pnpm --filter @school-sis/web run db:seed",
    "db:studio": "pnpm --filter @school-sis/web run db:studio",
    "scheduler": "node --env-file=apps/web/.env.local scripts/scheduler.mjs",
    "jobs:tick": "node --env-file=apps/web/.env.local scripts/scheduler.mjs --once",
    "perf:bundle": "pnpm --filter @school-sis/web run perf:bundle",
    "perf:load": "pnpm --filter @school-sis/web run perf:load",
    "audit:security": "pnpm audit --json > pnpm-audit-high.json || true && pnpm audit:check -- pnpm-audit-high.json",
    "audit:check": "node scripts/check-pnpm-audit-high.mjs",
    "audit:secrets": "node scripts/check-secret-patterns.mjs",
    "audit:hygiene": "node scripts/check-repository-hygiene.mjs",
    "audit:debt": "node scripts/check-risk-debt.mjs",
    "audit:ci": "pnpm audit:security && pnpm audit:secrets && pnpm audit:hygiene && pnpm audit:debt",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "next": "^16.2.5",
    "prettier": "^3.2.0",
    "ts-jest": "^29.4.9",
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=9.0.7",
      "flatted": ">=3.4.2",
      "dompurify": ">=3.3.2",
      "lodash": ">=4.17.23",
      "jspdf": ">=4.2.1",
      "jsonwebtoken": ">=9.0.2",
      "picomatch": ">=4.0.4",
      "next": ">=16.2.5"
    }
  }
}
