         id: bounty.id,\n                  name: bounty.name,\n                },\n                partner: {\n                  id: partner.id,\n                  name: partner.name,\n                  image: partner.image,\n                  email: partner.email ?? \"\",\n                },\n                submission: {\n                  id: submission.id,\n                },\n              }),\n            })),\n          );\n        }\n\n        if (partner.email && program) {\n          await sendEmail({\n            subject: \"Bounty submitted!\",\n            to: partner.email,\n            replyTo: program.supportEmail || \"noreply\",\n            react: BountySubmitted({\n              email: partner.email,\n              bounty: {\n                name: bounty.name,\n              },\n              program: {\n                name: program.name,\n                slug: program.slug,\n              },\n            }),\n          });\n        }\n      })", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/bounty/api/create-bounty-submission.ts", "source_location": "L599"}, {"caller_nid": "create_bounty_submission_getplatformfromsocialurl", "callee": "trim", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/bounty/api/create-bounty-submission.ts", "source_location": "L658"}, {"caller_nid": "create_bounty_submission_getplatformfromsocialurl", "callee": "isValidUrl", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/bounty/api/create-bounty-submission.ts", "source_location": "L660"}, {"caller_nid": "create_bounty_submission_getplatformfromsocialurl", "callee": "replace", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/bounty/api/create-bounty-submission.ts", "source_location": "L666"}]}