llee": "log", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L252"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "getRewardAmount", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L269"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "calculateSaleEarnings", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L272"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "create", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L281"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "createId", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L283"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "log", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L314"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "currencyFormatter", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L315"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "prettyPrint", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L315"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "toCentsNumber", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L321"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "waitUntil", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L324"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "(async () => {\n        const program = await prisma.program.findUniqueOrThrow({\n          where: {\n            id: programId,\n          },\n          select: {\n            id: true,\n            name: true,\n            slug: true,\n            logo: true,\n            supportEmail: true,\n            workspace: {\n              select: {\n                id: true,\n                slug: true,\n                name: true,\n                webhookEnabled: true,\n              },\n            },\n            // if no partner group is found, need to fetch default group to fallback to\n            ...(!programEnrollment.partnerGroup && {\n              groups: {\n                select: {\n                  holdingPeriodDays: true,\n                },\n                where: {\n                  slug: DEFAULT_PARTNER_GROUP.slug,\n                },\n              },\n            }),\n          },\n        });\n\n        const { workspace } = program;\n        const isClawback = earnings < 0;\n        const shouldTriggerWorkflow = !isClawback && !skipWorkflow;\n\n        await Promise.allSettled([\n          sendWorkspaceWebhook({\n            workspace,\n            trigger: \"commission.created\",\n            data: CommissionWebhookSchema.parse({\n              ...commission,\n              partner: webhookPartner,\n            }),\n          }),\n\n          sendPartnerPostback({\n            partnerId,\n            event: \"commission.created\",\n            data: {\n              ...commission,\n              customer: commission.customer,\n            },\n          }),\n\n          syncTotalCommissions({\n            partnerId,\n            programId,\n          }),\n\n          !isClawback &&\n            notifyPartnerCommission({\n              program,\n              // fallback to default group if no partner group is found\n              group: programEnrollment.partnerGroup ?? program.groups[0],\n              workspace,\n              commission,\n              isFirstCommission: firstCommission === null,\n            }),\n\n          // We only capture audit logs for manual commissions\n          user &&\n            recordAuditLog({\n              workspaceId: workspace.id,\n              programId,\n              action: isClawback ? \"clawback.created\" : \"commission.created\",\n              description: isClawback\n                ? `Clawback created for ${partnerId}`\n                : `Commission created for ${partnerId}`,\n              actor: user,\n              targets: [\n                {\n                  type: isClawback ? \"clawback\" : \"commission\",\n                  id: commission.id,\n                  metadata: commission,\n                },\n              ],\n            }),\n\n          shouldTriggerWorkflow &&\n            executeWorkflows({\n              trigger: \"partnerMetricsUpdated\",\n              reason: \"commission\",\n              identity: {\n                workspaceId: workspace.id,\n                programId,\n                partnerId,\n              },\n              metrics: {\n                current: {\n                  commissions: commission.earnings,\n                },\n              },\n            }),\n        ]);\n      })", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L325"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "error", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L440"}, {"caller_nid": "create_partner_commission_createpartnercommission", "callee": "log", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/partners/create-partner-commission.ts", "source_location": "L442"}]}