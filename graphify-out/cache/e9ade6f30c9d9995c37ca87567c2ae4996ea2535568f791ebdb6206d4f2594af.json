reatedAt: application.createdAt,\n            partner: {\n              ...partner,\n              ...programEnrollment,\n              id: partner.id,\n              ...formatWebsiteAndSocialsFields(application),\n            },\n            applicationFormData,\n          }),\n        }),\n\n        // Detect and record fraud events for the partner when they apply to a program\n        detectAndRecordFraudApplication({\n          context: {\n            program,\n            partner,\n          },\n        }),\n      ]);\n    })", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/actions/partners/create-program-application.ts", "source_location": "L322"}, {"caller_nid": "create_program_application_createapplication", "callee": "create", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/actions/partners/create-program-application.ts", "source_location": "L397"}, {"caller_nid": "create_program_application_createapplication", "callee": "createId", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/actions/partners/create-program-application.ts", "source_location": "L400"}, {"caller_nid": "create_program_application_createapplication", "callee": "cookies", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/actions/partners/create-program-application.ts", "source_location": "L407"}, {"caller_nid": "create_program_application_createapplication", "callee": "split", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/actions/partners/create-program-application.ts", "source_location": "L410"}, {"caller_nid": "create_program_application_createapplication", "callee": "get", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/actions/partners/create-program-application.ts", "source_location": "L410"}, {"caller_