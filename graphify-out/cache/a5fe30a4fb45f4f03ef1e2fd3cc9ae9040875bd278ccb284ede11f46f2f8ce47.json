tion": "L30", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_tinybird_record_click_ts", "target": "record_click_sendlinkclickwebhooks", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L296", "weight": 1.0}], "raw_calls": [{"caller_nid": "record_click_recordclick", "callee": "has", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L70"}, {"caller_nid": "record_click_recordclick", "callee": "has", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L70"}, {"caller_nid": "record_click_recordclick", "callee": "userAgent", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L74"}, {"caller_nid": "record_click_recordclick", "callee": "detectBot", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L78"}, {"caller_nid": "record_click_recordclick", "callee": "log", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L82"}, {"caller_nid": "record_click_recordclick", "callee": "getIdentityHash", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L90"}, {"caller_nid": "record_click_recordclick", "callee": "get", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L97"}, {"caller_nid": "record_click_recordclick", "callee": "error", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L106"}, {"caller_nid": "record_click_recordclick", "callee": "detectQr", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L112"}, {"caller_nid": "record_click_recordclick", "callee": "get", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L123"}, {"caller_nid": "record_click_recordclick", "callee": "get", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L124"}, {"caller_nid": "record_click_recordclick", "callee": "geolocation", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L129"}, {"caller_nid": "record_click_recordclick", "callee": "ipAddress", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L131"}, {"caller_nid": "record_click_recordclick", "callee": "includes", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L132"}, {"caller_nid": "record_click_recordclick", "callee": "get", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L134"}, {"caller_nid": "record_click_recordclick", "callee": "toISOString", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L137"}, {"caller_nid": "record_click_recordclick", "callee": "now", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L137"}, {"caller_nid": "record_click_recordclick", "callee": "trim", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L147"}, {"caller_nid": "record_click_recordclick", "callee": "capitalize", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L155"}, {"caller_nid": "record_click_recordclick", "callee": "getDomainWithoutWWW", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L168"}, {"caller_nid": "record_click_recordclick", "callee": "set", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L176"}, {"caller_nid": "record_click_recordclick", "callee": "waitUntil", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L179"}, {"caller_nid": "record_click_recordclick", "callee": "(async () => {\n      const response = await Promise.allSettled([\n        fetchWithRetry(\n          `${process.env.TINYBIRD_API_URL}/v0/events?name=dub_click_events&wait=true`,\n          {\n            method: \"POST\",\n            headers: {\n              Authorization: `Bearer ${process.env.TINYBIRD_API_KEY}`,\n            },\n            body: JSON.stringify(clickData),\n          },\n        ).then((res) => res.json()),\n\n        // cache the recorded click for the corresponding IP address in Redis for 1 hour\n        recordClickCache.set({ domain, key, identityHash, clickId }),\n\n        // increment the click count for the link (based on their ID)\n        // we have to use planetscale connection directly (not prismaEdge) because of connection pooling\n        conn.execute(\n          \"UPDATE Link SET clicks = clicks + 1, lastClicked = NOW() WHERE id = ?\",\n          [linkId],\n        ),\n        // if the link is associated with a workspace + has a destination URL\n        // increment the usage count for the workspace\n        workspaceId &&\n          url &&\n          publishClickEvent({\n            linkId,\n            workspaceId,\n            timestamp: clickData.timestamp,\n          }).catch(() => {\n            // Fallback on writing directly to the database\n            return conn.execute(\n              \"UPDATE Project p JOIN Link l ON p.id = l.projectId SET p.usage = p.usage + 1, p.totalClicks = p.totalClicks + 1 WHERE l.id = ?\",\n              [linkId],\n            );\n          }),\n\n        programId &&\n          partnerId &&\n          publishPartnerActivityEvent({\n            programId,\n            partnerId,\n            eventType: \"click\",\n            timestamp: new Date().toISOString(),\n          }).catch(() => {\n            // Fallback on writing directly to the database\n            return conn.execute(\n              \"UPDATE ProgramEnrollment SET totalClicks = totalClicks + 1 WHERE programId = ? AND partnerId = ?\",\n              [programId, partnerId],\n            );\n          }),\n      ]);\n\n      // Find the rejected promises and log them\n      if (response.some((result) => result.status === \"rejected\")) {\n        const errors = response\n          .map((result, index) => {\n            if (result.status === \"rejected\") {\n              const operations = [\n                \"Tinybird click event ingestion\",\n                \"recordClickCache set\",\n                \"Link clicks increment\",\n                \"Workspace usage increment\",\n                \"Program enrollment totalClicks increment\",\n              ];\n              return {\n                operation: operations[index] || `Operation ${index}`,\n                error: result.reason,\n                errorString: JSON.stringify(result.reason, null, 2),\n              };\n            }\n            return null;\n          })\n          .filter((err): err is NonNullable<typeof err> => err !== null);\n\n        console.error(\"[Record click] - Rejected promises:\", {\n          totalErrors: errors.length,\n          errors: errors.map((err) => ({\n            operation: err.operation,\n            error: err.error,\n            errorString: err.errorString,\n          })),\n        });\n      }\n\n      // if the link has webhooks enabled, we need to check if the workspace usage has exceeded the limit\n      const hasWebhooks = webhookIds && webhookIds.length > 0;\n      if (workspaceId && hasWebhooks) {\n        const workspaceRows = await conn.execute(\n          \"SELECT usage, usageLimit FROM Project WHERE id = ? LIMIT 1\",\n          [workspaceId],\n        );\n\n        const workspaceData =\n          workspaceRows.rows.length > 0\n            ? (workspaceRows.rows[0] as Pick<\n                WorkspaceProps,\n                \"usage\" | \"usageLimit\"\n              >)\n            : null;\n\n        const hasExceededUsageLimit =\n          workspaceData && workspaceData.usage >= workspaceData.usageLimit;\n\n        // Send webhook events if link has webhooks enabled and the workspace usage has not exceeded the limit\n        if (!hasExceededUsageLimit) {\n          await sendLinkClickWebhooks({ webhookIds, linkId, clickData });\n        }\n      }\n    })", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L180"}, {"caller_nid": "record_click_sendlinkclickwebhooks", "callee": "mget", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L305"}, {"caller_nid": "record_click_sendlinkclickwebhooks", "callee": "filter", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L313"}, {"caller_nid": "record_click_sendlinkclickwebhooks", "callee": "then", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L326"}, {"caller_nid": "record_click_sendlinkclickwebhooks", "callee": "execute", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L326"}, {"caller_nid": "record_click_sendlinkclickwebhooks", "callee": "sendWebhooks", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L352"}, {"caller_nid": "record_click_sendlinkclickwebhooks", "callee": "transformClickEventData", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L356"}, {"caller_nid": "record_click_sendlinkclickwebhooks", "callee": "transformLink", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/tinybird/record-click.ts", "source_location": "L358"}]}