urce_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L24", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_links_create_link_ts", "target": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_links_utils", "relation": "imports_from", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L25", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_links_create_link_ts", "target": "create_link_createlink", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L27", "weight": 1.0}], "raw_calls": [{"caller_nid": "create_link_createlink", "callee": "combineTagIds", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L43"}, {"caller_nid": "create_link_createlink", "callee": "getParamsFromURL", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L46"}, {"caller_nid": "create_link_createlink", "callee": "encodeKeyIfCaseSensitive", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L50"}, {"caller_nid": "create_link_createlink", "callee": "withPrismaRetry", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L55"}, {"caller_nid": "create_link_createlink", "callee": "waitUntil", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L142"}, {"caller_nid": "create_link_createlink", "callee": "(async () => {\n      const { partner, discount } = await getPartnerEnrollmentInfo({\n        programId: response.programId,\n        partnerId: response.partnerId,\n      });\n\n      await Promise.allSettled([\n        // Cache link in Redis\n        linkCache.set({\n          ...response,\n          ...(partner && { partner }),\n          ...(discount && { discount }),\n        }),\n\n        // Record link in Tinybird\n        recordLink({\n          ...response,\n          ...(partner?.groupId && {\n            programEnrollment: { groupId: partner.groupId },\n          }),\n        }),\n\n        // Upload image to R2 and update the link with the uploaded image URL when\n        // proxy is enabled and image is set and is not a hosted image URL\n        ...(proxy && image && isNotHostedImage(image)\n          ? [\n              // upload image to R2\n              storage.upload({\n                key: `images/${response.id}`,\n                body: image,\n                opts: {\n                  width: 1200,\n                  height: 630,\n                },\n              }),\n              // update the null image we set earlier to the uploaded image URL\n              prisma.link.update({\n                where: {\n                  id: response.id,\n                },\n                data: {\n                  image: uploadedImageUrl,\n                },\n              }),\n            ]\n          : []),\n\n        // Delete public links after 30 mins\n        !response.userId &&\n          qstash.publishJSON({\n            url: `${APP_DOMAIN_WITH_NGROK}/api/cron/links/delete`,\n            // delete after 30 mins\n            delay: 30 * 60,\n            body: {\n              linkId: response.id,\n            },\n          }),\n\n        // Update links usage for workspace\n        link.projectId &&\n          updateLinksUsage({\n            workspaceId: link.projectId,\n            increment: 1,\n          }),\n\n        // Propagate webhook trigger changes\n        webhookIds &&\n          propagateWebhookTriggerChanges({\n            webhookIds,\n          }),\n\n        // Schedule AB test completion\n        testVariants && testCompletedAt && scheduleABTestCompletion(response),\n      ]);\n    })", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L143"}, {"caller_nid": "create_link_createlink", "callee": "transformLink", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L221"}, {"caller_nid": "create_link_createlink", "callee": "isNotHostedImage", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/links/create-link.ts", "source_location": "L224"}]}