rsonal_school_sis_reference_architectures_dub_apps_web_lib_api_activity_log_track_activity_log", "relation": "imports_from", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L9", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_groups_move_partners_to_group_ts", "target": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_get_workspace_users", "relation": "imports_from", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L13", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_groups_move_partners_to_group_ts", "target": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_links_include_program_enrollment", "relation": "imports_from", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L14", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_groups_move_partners_to_group_ts", "target": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_links_include_tags", "relation": "imports_from", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L15", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_groups_move_partners_to_group_ts", "target": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_partners_notify_partner_group_change", "relation": "imports_from", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L16", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_groups_move_partners_to_group_ts", "target": "move_partners_to_group_movepartnerstogroup", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L36", "weight": 1.0}], "raw_calls": [{"caller_nid": "move_partners_to_group_movepartnerstogroup", "callee": "findMany", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L49"}, {"caller_nid": "move_partners_to_group_movepartnerstogroup", "callee": "map", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L73"}, {"caller_nid": "move_partners_to_group_movepartnerstogroup", "callee": "updateMany", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L75"}, {"caller_nid": "move_partners_to_group_movepartnerstogroup", "callee": "waitUntil", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L96"}, {"caller_nid": "move_partners_to_group_movepartnerstogroup", "callee": "(async () => {\n      const partnerLinks = await prisma.link.findMany({\n        where: {\n          programId,\n          partnerId: {\n            in: partnerIds,\n          },\n        },\n        include: {\n          ...includeTags,\n          ...includeProgramEnrollment,\n        },\n      });\n\n      const updatedProgramEnrollments = await prisma.programEnrollment.findMany(\n        {\n          where: {\n            partnerId: {\n              in: partnerIds,\n            },\n            programId,\n          },\n          select: {\n            id: true,\n            partnerId: true,\n            partnerGroup: {\n              select: {\n                id: true,\n                name: true,\n              },\n            },\n          },\n        },\n      );\n\n      // Build activity log inputs\n      const activityLogInputs: TrackActivityLogInput[] =\n        updatedProgramEnrollments.map((updatedEnrollment) => {\n          const oldEnrollment = programEnrollments.find(\n            (e) => e.id === updatedEnrollment.id,\n          );\n\n          return {\n            workspaceId,\n            programId,\n            resourceType: \"partner\",\n            resourceId: updatedEnrollment.partnerId,\n            userId,\n            action: \"partner.groupChanged\",\n            changeSet: buildProgramEnrollmentChangeSet({\n              oldEnrollment,\n              newEnrollment: updatedEnrollment,\n            }),\n          };\n        });\n\n      // If the userId is not provided, get the workspace user id from the workspace users\n      // userId will be null for workflow-initiated actions\n      let workspaceUserId = userId;\n\n      if (!workspaceUserId) {\n        const { users } = await getWorkspaceUsers({\n          programId,\n          role: WorkspaceRole.owner,\n        });\n\n        if (users.length > 0) {\n          workspaceUserId = users[0].id;\n        }\n      }\n\n      await Promise.allSettled([\n        qstash.publishJSON({\n          url: `${APP_DOMAIN_WITH_NGROK}/api/cron/groups/remap-default-links`,\n          body: {\n            programId,\n            groupId: group.id,\n            // skip remap-default-links / remap-discount-codes for pending applications (no links yet)\n            partnerIds: programEnrollments\n              .filter(({ status }) => status !== \"pending\")\n              .map(({ partnerId }) => partnerId),\n            userId: workspaceUserId,\n            isGroupDeleted,\n          },\n        }),\n\n        triggerDraftBountySubmissionCreation({\n          programId,\n          partnerIds,\n        }),\n\n        recordLink(partnerLinks),\n\n        notifyPartnerGroupChange({\n          programId,\n          groupId: group.id,\n          partnerIds,\n        }),\n\n        trackActivityLog(activityLogInputs),\n      ]);\n    })", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/groups/move-partners-to-group.ts", "source_location": "L97"}]}