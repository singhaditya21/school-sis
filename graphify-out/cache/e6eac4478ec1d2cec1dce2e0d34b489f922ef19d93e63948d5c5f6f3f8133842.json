ectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L23", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_conversions_track_lead_ts", "target": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_workflows_execute_workflows", "relation": "imports_from", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L24", "weight": 1.0}, {"source": "users_adityasingh_personal_school_sis_reference_architectures_dub_apps_web_lib_api_conversions_track_lead_ts", "target": "track_lead_tracklead", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L32", "weight": 1.0}], "raw_calls": [{"caller_nid": "track_lead_tracklead", "callee": "findUnique", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L47"}, {"caller_nid": "track_lead_tracklead", "callee": "replaceAll", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L71"}, {"caller_nid": "track_lead_tracklead", "callee": "toLowerCase", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L71"}, {"caller_nid": "track_lead_tracklead", "callee": "createId", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L72"}, {"caller_nid": "track_lead_tracklead", "callee": "generateRandomName", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L74"}, {"caller_nid": "track_lead_tracklead", "callee": "isStored", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L76"}, {"caller_nid": "track_lead_tracklead", "callee": "nanoid", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L77"}, {"caller_nid": "track_lead_tracklead", "callee": "set", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L85"}, {"caller_nid": "track_lead_tracklead", "callee": "now", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L88"}, {"caller_nid": "track_lead_tracklead", "callee": "getClickEvent", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L110"}, {"caller_nid": "track_lead_tracklead", "callee": "findUnique", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L121"}, {"caller_nid": "track_lead_tracklead", "callee": "nanoid", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L148"}, {"caller_nid": "track_lead_tracklead", "callee": "upsert", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L174"}, {"caller_nid": "track_lead_tracklead", "callee": "createLeadEventPayload", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L202"}, {"caller_nid": "track_lead_tracklead", "callee": "isArray", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L203"}, {"caller_nid": "track_lead_tracklead", "callee": "all", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L207"}, {"caller_nid": "track_lead_tracklead", "callee": "set", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L210"}, {"caller_nid": "track_lead_tracklead", "callee": "set", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L214"}, {"caller_nid": "track_lead_tracklead", "callee": "waitUntil", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L224"}, {"caller_nid": "track_lead_tracklead", "callee": "(async () => {\n        // for deferred mode, we defer the lead event creation to a subsequent request\n        if (mode !== \"deferred\") {\n          await recordLead(createLeadEventPayload(customer.id));\n        }\n        if (\n          customerAvatar &&\n          !isStored(customerAvatar) &&\n          finalCustomerAvatar\n        ) {\n          // persist customer avatar to R2\n          await storage\n            .upload({\n              key: finalCustomerAvatar.replace(`${R2_URL}/`, \"\"),\n              body: customerAvatar,\n              opts: {\n                width: 128,\n                height: 128,\n              },\n            })\n            .catch(async (error) => {\n              console.error(\"Error persisting customer avatar to R2\", error);\n              // if the avatar fails to upload to R2, set the avatar to null in the database\n              if (customer) {\n                await prisma.customer.update({\n                  where: { id: customer.id },\n                  data: { avatar: null },\n                });\n              }\n            });\n        }\n\n        // if not deferred mode, process the following right away:\n        // - update link, workspace, and customer stats\n        // - for partner links, create partner commission and execute workflows\n        // - send lead.created webhook\n\n        if (mode !== \"deferred\") {\n          const [updatedLink, _project] = await Promise.all([\n            // update link leads count\n            prisma.link.update({\n              where: {\n                id: link.id,\n              },\n              data: {\n                leads: {\n                  increment: eventQuantity ?? 1,\n                },\n                lastLeadAt: new Date(),\n              },\n              include: includeTags,\n            }),\n\n            // update workspace events usage\n            prisma.project.update({\n              where: {\n                id: workspace.id,\n              },\n              data: {\n                usage: {\n                  increment: eventQuantity ?? 1,\n                },\n              },\n            }),\n          ]);\n          link = updatedLink; // update the link variable to the latest version\n\n          let createdCommission:\n            | Awaited<ReturnType<typeof createPartnerCommission>>\n            | undefined = undefined;\n\n          if (link.programId && link.partnerId && customer) {\n            createdCommission = await createPartnerCommission({\n              event: \"lead\",\n              programId: link.programId,\n              partnerId: link.partnerId,\n              linkId: link.id,\n              eventId: leadEventId,\n              customerId: customer.id,\n              quantity: eventQuantity ?? 1,\n              context: {\n                customer: {\n                  country: customer.country,\n                  source,\n                },\n              },\n            });\n\n            const { commission, webhookPartner, programEnrollment } =\n              createdCommission;\n\n            await Promise.allSettled([\n              executeWorkflows({\n                trigger: \"partnerMetricsUpdated\",\n                reason: \"lead\",\n                identity: {\n                  workspaceId: workspace.id,\n                  programId: link.programId,\n                  partnerId: link.partnerId,\n                },\n                metrics: {\n                  current: {\n                    leads: 1,\n                  },\n                },\n              }),\n\n              syncPartnerLinksStats({\n                partnerId: link.partnerId,\n                programId: link.programId,\n                eventType: \"lead\",\n              }),\n\n              // only run fraud checks if the commission was created\n              commission &&\n                webhookPartner &&\n                detectAndRecordFraudEvent({\n                  program: { id: link.programId },\n                  partner: pick(webhookPartner, [\"id\", \"email\", \"name\"]),\n                  programEnrollment: pick(programEnrollment, [\"status\"]),\n                  customer: pick(customer, [\"id\", \"email\", \"name\"]),\n                  link: pick(link, [\"id\"]),\n                  click: pick(clickData, [\"url\", \"referer\"]),\n                  event: { id: leadEventId },\n                }),\n            ]);\n          }\n\n          await Promise.allSettled([\n            sendWorkspaceWebhook({\n              trigger: \"lead.created\",\n              data: transformLeadEventData({\n                ...clickData,\n                eventName,\n                link,\n                customer,\n                partner: createdCommission?.webhookPartner,\n                metadata,\n              }),\n              workspace,\n            }),\n\n            ...(link.partnerId\n              ? [\n                  sendPartnerPostback({\n                    partnerId: link.partnerId,\n                    event: \"lead.created\",\n                    data: {\n                      ...clickData,\n                      eventName,\n                      link,\n                      customer,\n                    },\n                  }),\n                ]\n              : []),\n          ]);\n        }\n      })", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L225"}, {"caller_nid": "track_lead_tracklead", "callee": "parse", "source_file": "/Users/adityasingh/Personal/School-sis/Reference-Architectures/dub/apps/web/lib/api/conversions/track-lead.ts", "source_location": "L387"}]}