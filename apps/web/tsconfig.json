{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "drizzle-orm": [
        "./node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "./node_modules/drizzle-orm/*"
      ],
      "pg": [
        "./node_modules/pg"
      ],
      "pg/*": [
        "./node_modules/pg/*"
      ],
      "@/lib/db": [
        "../../packages/api/src/db/index.ts"
      ],
      "@/lib/db/*": [
        "../../packages/api/src/db/*"
      ],
      "@/lib/services/*": [
        "../../packages/api/src/services/*"
      ],
      "@/lib/validations": [
        "../../packages/api/src/validations.ts"
      ],
      "@/lib/config/limits": [
        "../../packages/api/src/config/limits.ts"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "src/graphify-out",
    "src/__tests__",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
