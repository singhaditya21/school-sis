# School SIS — web environment contract
# Copy to .env.local for local development. Do not commit real secrets.
#
# Two sections:
#   1) REQUIRED — the production deploy gate (`pnpm infra:check --strict`) fails
#      without these. This is the complete must-have set.
#   2) OPTIONAL — capabilities are opt-in. Leave them unset to ship a lean deploy;
#      the app degrades gracefully (no online payments, in-app notifications only,
#      etc.). Enable a capability by setting its selector + secrets.

# ─────────────────────────────────────────────────────────────────────────────
# 1) REQUIRED (8)
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated production tenant base domains (hostnames only, no protocol).
# Example: school.example.edu,portal.example.edu   (localhost is fine for dev)
TENANT_BASE_HOSTS=localhost

# Local Postgres (scripts/local-db.sh, port 5433, pgvector). DIRECT_URL is the
# same locally; it exists so drizzle tooling and the app can use distinct URLs.
DATABASE_URL=postgresql://postgres@localhost:5433/school_sis?sslmode=disable
DIRECT_URL=postgresql://postgres@localhost:5433/school_sis?sslmode=disable

# Secrets — each at least 32 random characters.
SESSION_SECRET=replace_with_at_least_32_random_characters
PII_ENCRYPTION_KEY=replace_with_at_least_32_random_characters   # or set ENCRYPTION_KEY instead
JOB_DISPATCH_SECRET=replace_with_at_least_32_random_characters  # secures /api/jobs/dispatch
CRON_SECRET=replace_with_at_least_32_random_characters          # required when using Vercel Cron

# ─────────────────────────────────────────────────────────────────────────────
# 2) OPTIONAL — capabilities (unset = disabled, app degrades gracefully)
# ─────────────────────────────────────────────────────────────────────────────

# Runtime modes
NODE_ENV=development
INTEGRATIONS_MODE=mock
JOB_QUEUE_MODE=database

# Online payments — single provider. Unset/none = payments disabled.
# PAYMENT_PROVIDER=stripe        # or: razorpay
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...

# External notifications — unset = in-app only. Opt in per channel.
# REQUIRED_NOTIFICATION_CHANNELS=email,sms,push
# EMAIL_PROVIDER=resend          # or: smtp
# RESEND_API_KEY=...
# SMTP_HOST= / SMTP_USER= / SMTP_PASS=
# SMS_PROVIDER=msg91             # or: twilio
# MSG91_AUTH_KEY=...
# TWILIO_ACCOUNT_SID=AC... / TWILIO_AUTH_TOKEN=... / TWILIO_FROM_NUMBER=...
# PUSH_PROVIDER=firebase
# FIREBASE_PROJECT_ID= / FIREBASE_CLIENT_EMAIL= / FIREBASE_PRIVATE_KEY=

# File storage — unset = upload/download features unavailable. Prefer R2.
# R2_ACCOUNT_ID= / R2_ACCESS_KEY_ID= / R2_SECRET_ACCESS_KEY= / R2_BUCKET_NAME=
# STORAGE_CDN_BASE_URL=https://cdn.example.com
# AWS_REGION= / AWS_ACCESS_KEY_ID= / AWS_SECRET_ACCESS_KEY= / AWS_S3_BUCKET=   # S3 fallback

# AI features (external agent service) — unset = AI routes out of scope.
# AI_FEATURES_ENABLED=true
# AGENT_SERVICE_URL=https://agents.example.com
# AGENT_API_TOKEN=replace_with_at_least_32_random_characters
# AGENT_WEBHOOK_SECRET=replace_with_at_least_32_random_characters
# CEREBRAS_API_KEY= / CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Observability & throttling
# METRICS_TOKEN=replace_with_at_least_32_random_characters   # enables /api/metrics
# NEXT_PUBLIC_SENTRY_DSN=
# UPSTASH_REDIS_REST_URL= / UPSTASH_REDIS_REST_TOKEN=        # else Postgres rate-limit fallback

# Backup runbook
# BACKUP_RETENTION_DAYS=30
# BACKUP_DIR=./backups/neon

# IoT ingest (optional)
# IOT_INGEST_SECRET=replace_with_at_least_32_random_characters
# IOT_SYSTEM_USER_ID=00000000-0000-4000-8000-000000000000

# Perf/load-test tunables (dev only)
BUNDLE_MAX_TOTAL_KB=10000
BUNDLE_MAX_ROUTE_KB=2500
