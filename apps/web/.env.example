# ScholarMind — Environment Variables
# Copy this to .env and fill in your values

# REQUIRED: Session encryption secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Database (Neon.tech or local Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/scholarmind?sslmode=require

# REQUIRED: PII encryption key for DPDPA compliance (64-char hex = 256-bit key)
# Generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# Stripe (get from Stripe Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Razorpay (get from Razorpay Dashboard → Settings → API Keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
