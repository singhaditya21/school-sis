# School SIS web environment contract
# Copy to .env.local for local development. Do not commit real secrets.

# Runtime mode
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTEGRATIONS_MODE=mock
JOB_QUEUE_MODE=database

# Neon Postgres
# Use the pooled Neon URL for app runtime and the direct Neon URL for migrations.
DATABASE_URL=postgresql://user:password@ep-example-pooler.us-east-1.aws.neon.tech/school_sis?sslmode=require
DIRECT_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/school_sis?sslmode=require

# Core security
SESSION_SECRET=replace_with_at_least_32_random_characters
PII_ENCRYPTION_KEY=replace_with_at_least_32_random_characters
ENCRYPTION_KEY=replace_with_at_least_32_random_characters
NEXTAUTH_SECRET=replace_with_at_least_32_random_characters
NEXTAUTH_URL=http://localhost:3000

# Platform operations
METRICS_TOKEN=replace_with_at_least_32_random_characters
AGENT_WEBHOOK_SECRET=replace_with_at_least_32_random_characters
AGENT_API_TOKEN=replace_with_at_least_32_random_characters
AGENT_SERVICE_URL=http://localhost:8000
IOT_INGEST_SECRET=replace_with_at_least_32_random_characters
IOT_SYSTEM_USER_ID=00000000-0000-4000-8000-000000000000

# AI provider
CEREBRAS_API_KEY=replace_with_cerebras_api_key
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Payments
PAYMENT_PROVIDER_MODE=mock
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

# Storage and signed retrieval
# Prefer Cloudflare R2. AWS S3 is supported as a fallback.
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET_NAME=school-sis-uploads
STORAGE_CDN_BASE_URL=https://cdn.example.com

# AWS S3 fallback
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
AWS_S3_BUCKET=school-sis-uploads

# Backup runbook defaults
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=./backups/neon

# Optional providers
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
FIREBASE_PROJECT_ID=replace_me
FIREBASE_CLIENT_EMAIL=firebase-admin@example.com
FIREBASE_PRIVATE_KEY=replace_with_newline_escaped_private_key
EMAIL_PROVIDER=mock
SMS_PROVIDER=mock
WHATSAPP_PROVIDER=mock
PUSH_PROVIDER=mock
